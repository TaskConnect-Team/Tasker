atlas_URL=your-mongodb-connection-string
JWT_SECRET=your-jwt-secret
EMAIL_USER=your-gmail-address
EMAIL_PASS=your-gmail-app-password

STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Admin credentials — ADMIN_PASSWORD must be a bcrypt hash.
# Generate one with: node -e "import('bcryptjs').then(b=>b.default.hash('yourpassword',10).then(console.log))"
ADMIN_EMAIL=your-admin-email
ADMIN_PASSWORD=your-bcrypt-hashed-password

# Comma-separated list with no trailing slashes
ALLOWED_ORIGINS=http://localhost:5173
